# Exsa-Engine Configuration

# Model settings
MODEL_PATH=models/model.gguf
GPU_LAYERS=32                 # BEAST MODE: Set to 999 for full GPU offload
CONTEXT_SIZE=4096             # BEAST MODE: Doubled from 2048 (was 2048)
BATCH_SIZE=1024               # BEAST MODE: Doubled from 512 (was not configurable)

# 🔥 BEAST MODE: Speculative Decoding (2-3x speedup!)
ENABLE_SPECULATIVE=false      # Set to 'true' to enable speculative decoding
DRAFT_MODEL_PATH=models/tinyllama-1b-q4.gguf  # Small, fast draft model
SPECULATION_DEPTH=5           # How many tokens to predict ahead (3-7 recommended)

# 🔥 BEAST MODE: Continuous Batching (3-5x throughput!)
ENABLE_CONTINUOUS_BATCHING=false  # Set to 'true' to enable continuous batching
MAX_BATCH_SIZE=8              # Max concurrent requests in a batch
BATCH_TIMEOUT_MS=100          # Max wait time before processing batch (ms)
KV_CACHE_POOL_SIZE=16         # Number of pooled KV caches
SCHEDULING_STRATEGY=fifo      # fifo, shortest, priority, dynamic

# Server settings (Security)
# HOST=127.0.0.1  # Localhost only (most secure, default)
HOST=0.0.0.0      # LAN access (use with caution)
PORT=3000

# Queue settings
MAX_QUEUE_SIZE=100

# Security settings
ENABLE_CORS=false           # Disable CORS by default (secure)
ENABLE_RATE_LIMIT=true      # Enable rate limiting (recommended)
RATE_LIMIT_MAX=60           # Max requests per window
RATE_LIMIT_WINDOW=60        # Window in seconds (60 = 1req/sec avg)

# Logging
RUST_LOG=exsa_engine=info,tower_http=debug

# Benchmark settings (for benchmark binary)
# BENCHMARK_REQUESTS=10
# BENCHMARK_CONCURRENT=1
# SERVER_URL=http://localhost:3000
